# =============================================
# 環境変数設定ファイル (.env.example)
# このファイルをコピーして .env.local を作成してください
# cp .env.example .env.local
# =============================================

# ==========================================
# Supabase 設定
# ==========================================
# JWTシークレット（本番環境では必ず変更してください）
JWT_SECRET=your-super-secret-jwt-secret-at-least-32-characters-long

# PostgreSQLパスワード（本番環境では必ず変更してください）
POSTGRES_PASSWORD=your-super-secret-password

# Supabase API Keys
# これらはローカル開発用の固定値です
# 本番環境ではSupabase Cloudのダッシュボードから取得してください
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRFA0NiK7ACcPpgfgtjiqbLsUkzlHpWW3VjWwqMm9Lo
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hj04zWl196z2-SBc0

# ==========================================
# アプリケーション設定
# ==========================================
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_ANON_KEY=${SUPABASE_ANON_KEY}
NEXT_PUBLIC_APP_NAME=婚活プラットフォーム
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ==========================================
# 外部URL設定
# ==========================================
API_EXTERNAL_URL=http://localhost:8000
SITE_URL=http://localhost:3000
ADDITIONAL_REDIRECT_URLS=

# ==========================================
# SMTP設定（メール送信）
# ==========================================
SMTP_HOST=inbucket
SMTP_PORT=2500
SMTP_USER=
SMTP_PASS=
ENABLE_EMAIL_AUTOCONFIRM=true

# ==========================================
# その他
# ==========================================
LOGFLARE_API_KEY=your-logflare-key
DISABLE_SIGNUP=false
JWT_EXPIRY=3600
